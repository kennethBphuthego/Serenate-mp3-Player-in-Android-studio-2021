<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/song_detail"
    android:fitsSystemWindows="true"
    android:layout_marginTop="2dp"
    android:background="@drawable/song_bg"
    android:layout_width="match_parent"
    android:layout_height="72dp">

   <ImageView
       android:layout_width="60dp"
       android:layout_height="67dp"
       android:id="@+id/song_img1"
       android:src="@drawable/ic_launcher_background"
       android:padding="5dp"
       tools:ignore="ContentDescription" />

   <TextView
       android:id="@+id/song_name1"
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:layout_alignParentTop="true"
       android:layout_marginStart="2dp"
       android:layout_marginTop="10dp"
       android:layout_toEndOf="@+id/song_img1"
       android:layout_toStartOf="@+id/song_options"
       android:text="File name"
       android:textSize="15sp"
       android:textColor="@color/white"
       tools:ignore="HardcodedText" />

   <TextView
       android:id="@+id/artist_name1"
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:layout_alignParentTop="true"
       android:layout_marginStart="2dp"
       android:layout_marginTop="43dp"
       android:layout_toEndOf="@+id/song_img1"
       android:layout_toStartOf="@+id/song_options"
       android:text="Artist name"
       android:textSize="11sp"
       android:textColor="#C7C3C3"
       tools:ignore="HardcodedText" />
   
    <ImageView
       android:layout_width="60dp"
       android:layout_height="72dp"
       android:layout_alignParentEnd="true"
       android:id="@+id/song_options"
       android:src="@drawable/btn_song_options"
       android:padding="12dp"
        tools:ignore="ContentDescription" />

</RelativeLayout>