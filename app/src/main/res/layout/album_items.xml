<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="170dp"
    android:layout_height="200dp"
    android:layout_margin="10dp"
    android:id="@+id/album_partitions"
    app:cardCornerRadius="8dp"
    app:cardElevation="8dp">

   <RelativeLayout
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:background="@drawable/bg3"
       android:id="@+id/album_single_box">

       <ImageView
           android:id="@+id/album_img1"
           android:layout_width="match_parent"
           android:layout_height="142dp"
           android:src="@drawable/ic_launcher_background"
           tools:ignore="ContentDescription" />

       <TextView
           android:id="@+id/album_name1"
           android:layout_width="130dp"
           android:layout_height="wrap_content"
           android:layout_below="@+id/album_img1"
           android:layout_alignParentStart="true"
           android:layout_alignParentEnd="true"
           android:layout_marginStart="18dp"
           android:layout_marginTop="7dp"
           android:layout_marginEnd="22dp"
           android:gravity="center_horizontal"
           android:singleLine="true"
           android:text="Album name"
           android:textColor="@color/white"
           android:textStyle="bold"
           tools:ignore="HardcodedText" />

       <TextView
           android:id="@+id/artist_name1"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:layout_below="@+id/album_name1"
           android:layout_alignParentStart="true"
           android:layout_alignParentEnd="true"
           android:layout_marginStart="54dp"
           android:layout_marginTop="8dp"
           android:layout_marginEnd="59dp"
           android:text="Artist name"
           android:textColor="#C7C3C3"
           android:textSize="11sp"
           tools:ignore="HardcodedText" />


   </RelativeLayout>



</androidx.cardview.widget.CardView >